<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <Description>Bağlantılı olan cari ve muhasebe hesaplarının bakiyelerinin kontrolü.</Description>
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>/LOGODB</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>d8dcfc6f-bbf0-4c76-8e3e-24a95050f96c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Tarih">
            <Value>=Parameters!Tarih.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CariDurum">
            <Value>=Parameters!CariDurum.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MuhasebeKod">
            <Value>=Parameters!MuhasebeKod.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CariBakiye">
            <Value>=Parameters!CariBakiye.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@MuhasebeBakiye">
            <Value>=Parameters!MuhasebeBakiye.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>WITH CTE(CariKod,CariHesap,MuhasebeKod,MuhasebeHesap,CariBakiye,MuhasebeBakiye)
AS
(

--DECLARE @Tarih datetime
--set @Tarih = '03.03.2021'

SELECT
CariKod,
CariHesap,



ISNULL(MuhasebeKod,'')AS MuhasebeKod,

ISNULL(MuhasebeHesap,'') AS MuhasebeHesap,



ISNULL((SELECT     SUM(CASE C.SIGN WHEN 0 THEN C.AMOUNT ELSE C.AMOUNT * - 1 END) FROM         LG_001_01_CLFLINE C WHERE     C.CANCELLED = 0 AND C.BRANCH = 1 AND C.PAIDINCASH &lt;&gt; 1 AND C.DATE_ &lt;= @Tarih AND C.CLIENTREF = A.LOGICALREF), 0) AS CariBakiye,



ISNULL((SELECT     SUM(F.DEBIT - F.CREDIT) FROM         LG_001_01_EMFLINE F WHERE     F.CANCELLED = 0 AND F.DATE_ &lt;= @Tarih AND F.ACCOUNTCODE = A.MuhasebeKod), 0) AS MuhasebeBakiye



FROM 
(SELECT     LOGICALREF, CODE AS CariKod, DEFINITION_ AS CariHesap,
(SELECT     ISNULL(MK.CODE,'') FROM LG_001_EMUHACC MK WHERE      MK.LOGICALREF = (SELECT     B.ACCOUNTREF FROM          LG_001_CRDACREF B WHERE      (B.TRCODE = 5) AND CK.LOGICALREF = B.CARDREF)   ) AS MuhasebeKod,
(SELECT     MK.DEFINITION_ FROM          LG_001_EMUHACC MK WHERE      MK.LOGICALREF = 
(SELECT     B.ACCOUNTREF FROM          LG_001_CRDACREF B WHERE      (B.TRCODE = 5) AND CK.LOGICALREF = B.CARDREF)) AS MuhasebeHesap FROM          LG_001_CLCARD CK WHERE CK.CARDTYPE &lt;&gt;22 AND CK.ACTIVE IN (@CariDurum) ) A

)

SELECT CariKod,CariHesap,MuhasebeKod,MuhasebeHesap,round(CariBakiye,2)CariBakiye ,ROUND(MuhasebeBakiye,2) MuhasebeBakiye FROM CTE
WHERE  CASE WHEN MuhasebeKod  &lt;&gt; '' THEN  'Olanlar' else 'Olmayanlar' end IN(@MuhasebeKod)
AND  CASE WHEN round(CariBakiye,2)  &lt;&gt; 0 THEN  'Olanlar' else 'Olmayanlar' end IN(@CariBakiye)
AND  CASE WHEN round(MuhasebeBakiye,2)  &lt;&gt; 0 THEN  'Olanlar' else 'Olmayanlar' end IN(@MuhasebeBakiye)</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="CariKod">
          <DataField>CariKod</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CariHesap">
          <DataField>CariHesap</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MuhasebeKod">
          <DataField>MuhasebeKod</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MuhasebeHesap">
          <DataField>MuhasebeHesap</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CariBakiye">
          <DataField>CariBakiye</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="MuhasebeBakiye">
          <DataField>MuhasebeBakiye</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
