    <DataSet Name="Dataset2">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT
(SELECT TOP 1  SPC.DEFINITION_ FROM LG_001_SPECODES SPC WHERE SPC.SPECODE = SRC.SPECODE2 AND SPC.SPECODETYPE = 4 AND SPC.SPETYP2 = 1) AS 'Özel Kod2' ,
(SELECT TOP 1  SPC.DEFINITION_ FROM LG_001_SPECODES SPC WHERE SPC.SPECODE = SRC.SPECODE3 AND SPC.SPECODETYPE = 4 AND SPC.SPETYP3 =1) AS 'Özel Kod3' ,
(SELECT TOP 1  SPC.DEFINITION_ FROM LG_001_SPECODES SPC WHERE SPC.SPECODE = SRC.SPECODE4 AND SPC.SPECODETYPE = 4  AND SPC.SPETYP4 =1 ) AS 'Özel Kod4' ,

 SRC.DEFINITION2 as 'Hizmet Adı', '' Fatura FROM LG_001_SRVCARD SRC  WHERE SPECODE2 = 002</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Özel_Kod2">
          <DataField>Özel Kod2</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Özel_Kod3">
          <DataField>Özel Kod3</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Hizmet_Adı">
          <DataField>Hizmet Adı</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Özel_Kod4">
          <DataField>Özel Kod4</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Fatura">
          <DataField>Fatura</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet3">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SET language turkish
SELECT

INV.NETTOTAL AS 'Tutar',
concat(' ',
DATENAME(DAY,(SELECT top 1 DBO.LG_INTTODATE(FUTMONTHBEGDATE) FROM LG_001_01_STLINE STL WHERE INV.LOGICALREF = STL.INVOICEREF )), ' ',

DATENAME(MONTH,( SELECT top 1 DBO.LG_INTTODATE(FUTMONTHBEGDATE) FROM LG_001_01_STLINE STL WHERE INV.LOGICALREF = STL.INVOICEREF )), ' ',
DATENAME(DW,( SELECT top 1 DBO.LG_INTTODATE(FUTMONTHBEGDATE) FROM LG_001_01_STLINE STL WHERE INV.LOGICALREF = STL.INVOICEREF ))

) as 'Ödeme Tarih',
CASE WHEN OPSTAT = 3 THEN 'Bekliyor' when OPSTAT = 0 then  'Ödendi' end as 'Sonuç',

CONCAT(INV.GENEXP1, ' ' , INV.GENEXP2,' ',INV.GENEXP3, INV.GENEXP4,' ',INV.GENEXP5) AS 'Not',
DATEPART(YEAR,(SELECT top 1 DBO.LG_INTTODATE(FUTMONTHBEGDATE) FROM LG_001_01_STLINE STL WHERE INV.LOGICALREF = STL.INVOICEREF )) as 'Odeme Yil',
DATENAME(MONTH,(SELECT top 1 DBO.LG_INTTODATE(FUTMONTHBEGDATE) FROM LG_001_01_STLINE STL WHERE INV.LOGICALREF = STL.INVOICEREF )) as 'Odeme Ay'


FROM LG_001_01_INVOICE INV WHERE  INV.TRCODE = 04 AND INV.FICHENO = '00000669' AND BRANCH = 0</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Tutar">
          <DataField>Tutar</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="Ödeme_Tarih">
          <DataField>Ödeme Tarih</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Sonuç">
          <DataField>Sonuç</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Not">
          <DataField>Not</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Odeme_Yil">
          <DataField>Odeme Yil</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Odeme_Ay">
          <DataField>Odeme Ay</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="FaturaOzelKod">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT


SPC.DEFINITION_ AS 'FaturaOzelKod'

FROM LG_001_SPECODES SPC 
where 
SPC.SPECODETYPE = 22
AND SPC.CODETYPE = 1

UNION 
SELECT ''</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
