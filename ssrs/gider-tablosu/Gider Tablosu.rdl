<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=ERP;Initial Catalog=LOGODB</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>6386f73a-2e92-42c3-9228-c2bff04b2496</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@inpOdemeDurum">
            <Value>=Parameters!inpOdemeDurum.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@StartYear">
            <Value>=Parameters!StartYear.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@inpOdemeAy">
            <Value>=Parameters!inpOdemeAy.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@FaturaOzelKod">
            <Value>=Parameters!FaturaOzelKod.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@BankaFisleriOzelKod">
            <Value>=Parameters!BankaFisleriOzelKod.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@BankaFisleriFaturaOzelKod">
            <Value>=Parameters!BankaFisleriFaturaOzelKod.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CariHesapFisleriOzelKod">
            <Value>=Parameters!CariHesapFisleriOzelKod.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SET language turkish

-------FATURA ---------------
SELECT
CONVERT(varchar,INV.DATE_,104) 'Fatura Tarih',

INV.FICHENO AS 'Fatura No' , 
(SELECT top 1 SPC.DEFINITION_ FROM LG_001_SPECODES SPC WHERE SPC.SPECODE = INV.SPECODE AND SPC.SPECODETYPE = 22 ) AS 'Açıklama',
CONCAT(INV.GENEXP1, ' ' , INV.GENEXP2,' ',INV.GENEXP3, INV.GENEXP4,' ',INV.GENEXP5) AS 'Not',


concat(
DATEPART(DAY,INV.DOCDATE), ' ',
DATENAME(MONTH,INV.DOCDATE), ' ',
DATEPART(YEAR,(INV.DOCDATE)),' ',
DATENAME(DW,INV.DOCDATE)

) as 'Ödeme Tarih',

(SELECT TOP 1  SPC.DEFINITION_ FROM LG_001_SPECODES SPC WHERE  SPC.SPECODETYPE = 4  AND SPC.SPETYP4 =1  AND SPC.SPECODE = 
(SELECT TOP 1 SRV.SPECODE4 FROM LG_001_SRVCARD SRV WHERE SRV.LOGICALREF = (SELECT TOP 1 STL.STOCKREF FROM  LG_001_01_STLINE STL WHERE STL.INVOICEREF = INV.LOGICALREF )  ) ) AS Talimat,

DATEDIFF(DAY, GETDATE() ,DOCDATE)  AS 'Kalan Gün',

INV.NETTOTAL AS 'Tutar',


DATEPART(YEAR,DOCDATE)  as 'Odeme Yil' ,
DATENAME(MONTH,DOCDATE) as 'Odeme Ay', 
CASE WHEN OPSTAT = 3 THEN 'Bekliyor' when OPSTAT = 0 then  'Ödendi' end as 'Sonuç',

(SELECT TOP 1 DEFINITION_ FROM LG_001_CLCARD CLC WHERE CLC.LOGICALREF = INV.CLIENTREF) AS 'Cari Unvan',

'(04) A.H.F' as 'Evrak Tip',
INV.DOCDATE as 'OdemeZaman'

FROM LG_001_01_INVOICE INV WHERE  INV.TRCODE = 04 


AND BRANCH = 0

AND CASE WHEN OPSTAT = 3 THEN 'Bekliyor' when OPSTAT = 0 then  'Ödendi' END IN (@inpOdemeDurum)


AND DATEPART(YEAR,INV.DOCDATE) IN (@StartYear)
AND DATENAME(MONTH,INV.DOCDATE) IN (@inpOdemeAy)
AND (SELECT  SPC.DEFINITION_ FROM LG_001_SPECODES SPC WHERE SPC.SPECODE = INV.SPECODE AND SPC.SPECODETYPE = 22 AND  SPC.CODETYPE = 1 ) IN (@FaturaOzelKod)

AND ISNULL(INV.SPECODE,'') &lt;&gt; '' AND  ISNULL(INV.DOCDATE,'') &lt;&gt; ''

AND INV.FROMBANK = 0

--ORDER BY INV.DOCDATE ASC
--------------------------------------------------------------------------------------------
-------Banka Fişleri---------------
UNION 

--SET language turkish
SELECT BNF.DATE_ as  'Fatura Tarih',BNF.FICHENO AS 'Fatura No' ,
CASE WHEN BNF.TRCODE = 4 THEN (SELECT top 1 SPC.DEFINITION_ FROM LG_001_SPECODES SPC WHERE SPC.SPECODE = BNF.SPECODE AND SPC.SPECODETYPE = 43 AND CODETYPE = 1 ) 
WHEN BNF.TRCODE = 16 THEN (SELECT top 1 SPC.DEFINITION_ FROM LG_001_SPECODES SPC WHERE SPC.SPECODE = BNF.SPECODE AND SPC.SPECODETYPE = 22 AND SPC.CODETYPE = 1 )  END 
AS 'Açıklama',
CONCAT(BNF.GENEXP1, ' ',BNF.GENEXP2,' ',BNF.GENEXP3,' ',BNF.GENEXP4,' ',BNF.GENEXP5,' ',BNF.GENEXP6 ) AS 'Not', 
concat(
DATEPART(DAY,BNF.DATE_), ' ',
DATENAME(MONTH,BNF.DATE_), ' ',
DATEPART(YEAR,(BNF.DATE_)),' ',
DATENAME(DW,BNF.DATE_)

) as 'Ödeme Tarih',
(select top 1 BCC.DEFINITION_ FROM  LG_001_BANKACC BCC WHERE BCC.LOGICALREF  = (SELECT TOP 1 BFL.BNACCREF FROM LG_001_01_BNFLINE BFL WHERE BFL.SOURCEFREF = BNF.LOGICALREF  )) AS 'Talimat',
'' AS 'Kalan Gün',
BNF.CREDITTOT  AS  'Tutar',
DATEPART(YEAR,DATE_)  as 'Odeme Yil' ,
DATENAME(MONTH,DATE_) as 'Odeme Ay', 
CASE WHEN ISNULL(BNF.SPECODE,'') = '' THEN 'Bekliyor' when  ISNULL(BNF.SPECODE,'') &lt;&gt; ''  then  'Ödendi' end as 'Sonuç',

(SELECT TOP 1 DEFINITION_ from LG_001_CLCARD CLC WHERE CLC.LOGICALREF =(SELECT TOP 1 BNL.CLIENTREF FROM  LG_001_01_BNFLINE BNL  WHERE BNL.SOURCEFREF = BNF.LOGICALREF)  ) AS 'Cari Unvan',

CASE WHEN BNF.TRCODE = 4 THEN '(04) G.H/EFT ' WHEN BNF.TRCODE = 16 THEN '(16) B.A.H.F'  END  as 'Evrak Tip',

BNF.DATE_ as 'OdemeZaman'

FROM LG_001_01_BNFICHE BNF WHERE   BNF.TRCODE IN(4,16) AND BNF.BRANCH = 0 AND ISNULL(BNF.SPECODE,'') &lt;&gt; ''


and  CASE WHEN ISNULL(BNF.SPECODE,'') = '' THEN 'Bekliyor' when  ISNULL(BNF.SPECODE,'') &lt;&gt; ''  then  'Ödendi' end IN (@inpOdemeDurum)

AND DATEPART(YEAR,BNF.DATE_) IN (@StartYear)
AND DATENAME(MONTH,BNF.DATE_) IN (@inpOdemeAy)
AND BNF.TRCODE = 4

AND (SELECT  SPC.DEFINITION_ FROM LG_001_SPECODES SPC WHERE SPC.SPECODE = BNF.SPECODE AND SPC.SPECODETYPE = 43 AND CODETYPE = 1 ) IN (@BankaFisleriOzelKod)




--ORDER BY BNF.DATE_ ASC

-------------------------------------------------
--------------------------------------------------------------------------------------------
-------Banka Fişleri Fatura---------------
UNION 

--SET language turkish
SELECT BNF.DATE_ as  'Fatura Tarih',BNF.FICHENO AS 'Fatura No' ,
CASE WHEN BNF.TRCODE = 4 THEN (SELECT top 1 SPC.DEFINITION_ FROM LG_001_SPECODES SPC WHERE SPC.SPECODE = BNF.SPECODE AND SPC.SPECODETYPE = 43 AND CODETYPE = 1 ) 
WHEN BNF.TRCODE = 16 THEN (SELECT top 1 SPC.DEFINITION_ FROM LG_001_SPECODES SPC WHERE SPC.SPECODE = BNF.SPECODE AND SPC.SPECODETYPE = 22 AND SPC.CODETYPE = 1 )  END 
AS 'Açıklama',
CONCAT(BNF.GENEXP1, ' ',BNF.GENEXP2,' ',BNF.GENEXP3,' ',BNF.GENEXP4,' ',BNF.GENEXP5,' ',BNF.GENEXP6 ) AS 'Not', 
concat(
DATEPART(DAY,BNF.DATE_), ' ',
DATENAME(MONTH,BNF.DATE_), ' ',
DATEPART(YEAR,(BNF.DATE_)),' ',
DATENAME(DW,BNF.DATE_)

) as 'Ödeme Tarih',
(select top 1 BCC.DEFINITION_ FROM  LG_001_BANKACC BCC WHERE BCC.LOGICALREF  = (SELECT TOP 1 BFL.BNACCREF FROM LG_001_01_BNFLINE BFL WHERE BFL.SOURCEFREF = BNF.LOGICALREF  )) AS 'Talimat',
'' AS 'Kalan Gün',
BNF.CREDITTOT  AS  'Tutar',
DATEPART(YEAR,DATE_)  as 'Odeme Yil' ,
DATENAME(MONTH,DATE_) as 'Odeme Ay', 
CASE WHEN ISNULL(BNF.SPECODE,'') = '' THEN 'Bekliyor' when  ISNULL(BNF.SPECODE,'') &lt;&gt; ''  then  'Ödendi' end as 'Sonuç',

(SELECT TOP 1 DEFINITION_ from LG_001_CLCARD CLC WHERE CLC.LOGICALREF =(SELECT TOP 1 BNL.CLIENTREF FROM  LG_001_01_BNFLINE BNL  WHERE BNL.SOURCEFREF = BNF.LOGICALREF)  ) AS 'Cari Unvan',

CASE WHEN BNF.TRCODE = 4 THEN '(04) G.H/EFT ' WHEN BNF.TRCODE = 16 THEN '(16) B.A.H.F'  END  as 'Evrak Tip',

BNF.DATE_ as 'OdemeZaman'

FROM LG_001_01_BNFICHE BNF WHERE   BNF.TRCODE IN(16) AND BNF.BRANCH = 0 AND ISNULL(BNF.SPECODE,'') &lt;&gt; ''


AND CASE WHEN ISNULL(BNF.SPECODE,'') = '' THEN 'Bekliyor' when  ISNULL(BNF.SPECODE,'') &lt;&gt; ''  then  'Ödendi' end IN (@inpOdemeDurum)

AND DATEPART(YEAR,BNF.DATE_) IN (@StartYear)
AND DATENAME(MONTH,BNF.DATE_) IN (@inpOdemeAy)

AND (SELECT  SPC.DEFINITION_ FROM LG_001_SPECODES SPC WHERE SPC.SPECODE = BNF.SPECODE AND SPC.SPECODETYPE = 22 AND SPC.CODETYPE = 1 ) IN (@BankaFisleriFaturaOzelKod)



--ORDER BY BNF.DATE_ ASC

-------------------------------------------------


-------Cari Hesap Fişleri ---------------
UNION 

SELECT 

'' as  'Fatura Tarih',CLF.FICHENO AS 'Fatura No' ,
(SELECT top 1 SPC.DEFINITION_ FROM LG_001_SPECODES SPC WHERE SPC.SPECODE = CLF.SPECCODE AND SPC.SPECODETYPE = 44 AND CODETYPE = 1 ) AS 'Açıklama',
CONCAT(CLF.GENEXP1, ' ',CLF.GENEXP2,' ',CLF.GENEXP3,' ',CLF.GENEXP4,' ',CLF.GENEXP5,' ',CLF.GENEXP6 ) AS 'Not', 
concat(
DATEPART(DAY,CLF.DATE_), ' ',
DATENAME(MONTH,CLF.DATE_), ' ',
DATEPART(YEAR,(CLF.DATE_)),' ',
DATENAME(DW,CLF.DATE_)

) as 'Ödeme Tarih',
(select top 1 BCC.DEFINITION_ FROM  LG_001_BANKACC BCC WHERE BCC.LOGICALREF = CLF.BANKACCREF ) AS 'Talimat',
'' AS 'Kalan Gün',
CLF.DEBIT  AS  'Tutar',
DATEPART(YEAR,DATE_)  as 'Odeme Yil' ,
DATENAME(MONTH,DATE_) as 'Odeme Ay', 
CASE WHEN ISNULL(CLF.SPECCODE,'') = '' THEN 'Bekliyor' when  ISNULL(CLF.SPECCODE,'') &lt;&gt; ''  then  'Ödendi' end as 'Sonuç',

(SELECT TOP 1 DEFINITION_ from LG_001_CLCARD CLC WHERE CLC.LOGICALREF = CLF.CLCARDREF ) AS 'Cari Unvan',

'(72) F.K.K.F' AS 'Evrak Tip',

CLF.DATE_ as 'OdemeZaman'

FROM 	LG_001_01_CLFICHE CLF WHERE  CLF.BRANCH = 0  AND ISNULL(CLF.SPECCODE,'') &lt;&gt; '' AND CLF.TRCODE = 72

AND CASE WHEN ISNULL(CLF.SPECCODE,'') = '' THEN 'Bekliyor' when  ISNULL(CLF.SPECCODE,'') &lt;&gt; ''  then  'Ödendi' end IN (@inpOdemeDurum)

AND DATEPART(YEAR,CLF.DATE_) IN (@StartYear)
AND DATENAME(MONTH,CLF.DATE_) IN (@inpOdemeAy)
AND (SELECT SPC.DEFINITION_ FROM LG_001_SPECODES SPC WHERE SPC.SPECODE = CLF.SPECCODE AND SPC.SPECODETYPE = 44 AND SPC.CODETYPE = 1 ) IN (@CariHesapFisleriOzelKod)

order by OdemeZaman asc</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
