<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>/LOGODB</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>cb9965b5-84e8-4db2-97dc-620e4e1aeb78</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>---------------- SATIŞ ----------------------
SELECT '1' as 'SıraNo',  'Satış' as 'Kategori',
  SPCC.DEFINITION_ AS 'Grup',SPC.DEFINITION_ as 'Tür',
sum((CASE WHEN STL.VATINC  = 0  THEN  STL.TOTAL * (1 + STL.VAT /100) -  DISTCOST * (1 + STL.VAT /100)  ELSE   STL.TOTAL -  DISTCOST * (1 + STL.VAT /100)  END))AS 'Tutar'



FROM LG_001_01_STLINE STL 
INNER JOIN LG_001_01_INVOICE INV ON STL.INVOICEREF = INV.LOGICALREF
LEFT JOIN LG_001_ITEMS ITM ON STL.STOCKREF = ITM.LOGICALREF
LEFT JOIN LG_001_SPECODES SPC ON SPC.SPECODE = CASE WHEN STL.LINETYPE = 0 THEN ITM.SPECODE WHEN STL.LINETYPE  = 4 THEN (SELECT TOP 1 SPECODE FROM LG_001_SRVCARD SRV WHERE SRV.LOGICALREF = STL.STOCKREF) END
 
LEFT JOIN LG_001_SPECODES SPCC ON SPCC.SPECODE = ITM.STGRPCODE

WHERE 

INV.BRANCH =  0
AND INV.CANCELLED = 0 
AND INV.TRCODE IN (7,8) 
AND SPC.CODETYPE = 1
AND   SPC.SPECODETYPE  = CASE WHEN STL.LINETYPE = 0  THEN 1 WHEN STL.LINETYPE = 4 THEN 5 END
AND SPCC.SPECODETYPE = 0
AND SPCC.CODETYPE = 4
AND INV.DATE_ BETWEEN @StartDate AND @EndDate
GROUP BY  SPCC.DEFINITION_ ,SPC.DEFINITION_

UNION ALL




---------------- SATIŞ İADE  ----------------------

SELECT '2' as 'SıraNo', 'Satış İade (-)' as 'Kategori',
  SPCC.DEFINITION_ AS 'Grup',SPC.DEFINITION_ as 'Tür',
SUM((CASE WHEN STL.VATINC  = 0  THEN  STL.TOTAL * (1 + STL.VAT /100) -  DISTCOST * (1 + STL.VAT /100)  ELSE   STL.TOTAL -  DISTCOST * (1 + STL.VAT /100)  END)) AS 'Tutar'



FROM LG_001_01_STLINE STL 
INNER JOIN LG_001_01_INVOICE INV ON STL.INVOICEREF = INV.LOGICALREF
LEFT JOIN LG_001_ITEMS ITM ON STL.STOCKREF = ITM.LOGICALREF
LEFT JOIN LG_001_SPECODES SPC ON SPC.SPECODE = CASE WHEN STL.LINETYPE = 0 THEN ITM.SPECODE WHEN STL.LINETYPE  = 4 THEN (SELECT TOP 1 SPECODE FROM LG_001_SRVCARD SRV WHERE SRV.LOGICALREF = STL.STOCKREF) END
 
LEFT JOIN LG_001_SPECODES SPCC ON SPCC.SPECODE = ITM.STGRPCODE

WHERE 

INV.BRANCH =  0
AND INV.CANCELLED = 0 
AND INV.TRCODE IN (2,3) 
AND SPC.CODETYPE = 1
AND   SPC.SPECODETYPE  = CASE WHEN STL.LINETYPE = 0  THEN 1 WHEN STL.LINETYPE = 4 THEN 5 END
AND SPCC.SPECODETYPE = 0
AND SPCC.CODETYPE = 4
AND INV.DATE_ BETWEEN @StartDate AND @EndDate
GROUP BY  SPCC.DEFINITION_ ,SPC.DEFINITION_


UNION ALL
--------------   NET SATIŞ TOPLAMLARI -------------
SELECT '3' as 'SıraNo',  'Net Satış Toplamları' as 'Kategori',
CASE WHEN INV.TRCODE IN (7,8)  THEN  'Satış Toplamı'  else 'İade Toplamı' end AS 'Grup',
  CASE WHEN INV.TRCODE IN (7,8)  THEN  'Satış'  else 'İade' end as 'Tür',
case when INV.TRCODE IN (7,8) then sum((CASE WHEN STL.VATINC  = 0  THEN  STL.TOTAL * (1 + STL.VAT /100) -  DISTCOST * (1 + STL.VAT /100)  ELSE   STL.TOTAL -  DISTCOST * (1 + STL.VAT /100)  END))   when  INV.TRCODE IN (2,3)   then -1 * sum((CASE WHEN STL.VATINC  = 0  THEN  STL.TOTAL * (1 + STL.VAT /100) -  DISTCOST * (1 + STL.VAT /100)  ELSE   STL.TOTAL -  DISTCOST * (1 + STL.VAT /100)  END)) end   AS 'Tutar'



FROM LG_001_01_STLINE STL 
INNER JOIN LG_001_01_INVOICE INV ON STL.INVOICEREF = INV.LOGICALREF
LEFT JOIN LG_001_ITEMS ITM ON STL.STOCKREF = ITM.LOGICALREF
LEFT JOIN LG_001_SPECODES SPC ON SPC.SPECODE = CASE WHEN STL.LINETYPE = 0 THEN ITM.SPECODE WHEN STL.LINETYPE  = 4 THEN (SELECT TOP 1 SPECODE FROM LG_001_SRVCARD SRV WHERE SRV.LOGICALREF = STL.STOCKREF) END
 
LEFT JOIN LG_001_SPECODES SPCC ON SPCC.SPECODE = ITM.STGRPCODE

WHERE 

INV.BRANCH =  0
AND INV.CANCELLED = 0 
AND INV.TRCODE IN (2,3,7,8) 
AND SPC.CODETYPE = 1
AND   SPC.SPECODETYPE  = CASE WHEN STL.LINETYPE = 0  THEN 1 WHEN STL.LINETYPE = 4 THEN 5 END
AND SPCC.SPECODETYPE = 0
AND SPCC.CODETYPE = 4
AND INV.DATE_ BETWEEN @StartDate AND @EndDate
GROUP BY INV.TRCODE

UNION ALL
---------------- SATIŞ MALİYET  ----------------------
SELECT '4' as 'SıraNo',
'Satış Maliyet (-)' as 'Kategori',
  SPCC.DEFINITION_   AS 'Grup',SPC.DEFINITION_ as 'Tür',
SUM((STL.OUTCOST * STL.AMOUNT) * (1 + STL.VAT /100)) As 'Tutar'



FROM LG_001_01_STLINE STL 
INNER JOIN LG_001_01_INVOICE INV ON STL.INVOICEREF = INV.LOGICALREF
LEFT JOIN LG_001_ITEMS ITM ON STL.STOCKREF = ITM.LOGICALREF
LEFT JOIN LG_001_SPECODES SPC ON SPC.SPECODE = CASE WHEN STL.LINETYPE = 0 THEN ITM.SPECODE WHEN STL.LINETYPE  = 4 THEN (SELECT TOP 1 SPECODE FROM LG_001_SRVCARD SRV WHERE SRV.LOGICALREF = STL.STOCKREF) END
 
LEFT JOIN LG_001_SPECODES SPCC ON SPCC.SPECODE = ITM.STGRPCODE

WHERE 

INV.BRANCH =  0
AND INV.CANCELLED = 0 
AND INV.TRCODE IN (7,8) 
AND SPC.CODETYPE = 1
AND   SPC.SPECODETYPE  = CASE WHEN STL.LINETYPE = 0  THEN 1 WHEN STL.LINETYPE = 4 THEN 5 END
AND SPCC.SPECODETYPE = 0
AND SPCC.CODETYPE = 4
AND INV.DATE_ BETWEEN @StartDate AND @EndDate
GROUP BY SPCC.DEFINITION_ ,SPC.DEFINITION_

UNION ALL
------------------ SATIŞ İADE MALİYET ------------------------
SELECT '5' as 'SıraNo',
'Satış İade Maliyet (-)' as 'Kategori',
  SPCC.DEFINITION_   AS 'Grup',SPC.DEFINITION_ as 'Tür',
SUM((STL.RETCOST * STL.AMOUNT) * (1 + STL.VAT /100)) As 'Tutar'



FROM LG_001_01_STLINE STL 
INNER JOIN LG_001_01_INVOICE INV ON STL.INVOICEREF = INV.LOGICALREF
LEFT JOIN LG_001_ITEMS ITM ON STL.STOCKREF = ITM.LOGICALREF
LEFT JOIN LG_001_SPECODES SPC ON SPC.SPECODE = CASE WHEN STL.LINETYPE = 0 THEN ITM.SPECODE WHEN STL.LINETYPE  = 4 THEN (SELECT TOP 1 SPECODE FROM LG_001_SRVCARD SRV WHERE SRV.LOGICALREF = STL.STOCKREF) END
 
LEFT JOIN LG_001_SPECODES SPCC ON SPCC.SPECODE = ITM.STGRPCODE

WHERE 

INV.BRANCH =  0
AND INV.CANCELLED = 0 
AND INV.TRCODE IN (2,3) 
AND SPC.CODETYPE = 1
AND   SPC.SPECODETYPE  = CASE WHEN STL.LINETYPE = 0  THEN 1 WHEN STL.LINETYPE = 4 THEN 5 END
AND SPCC.SPECODETYPE = 0
AND SPCC.CODETYPE = 4
AND INV.DATE_ BETWEEN @StartDate AND @EndDate
GROUP BY SPCC.DEFINITION_ ,SPC.DEFINITION_

UNION ALL
---------------- GİDERLER (-) ----------------------

SELECT '6' as 'SıraNo',
'Giderler (-)' as 'Kategori',

(select TOP 1 DEFINITION_ from LG_001_SPECODES SPC WHERE SPC.SPECODETYPE  = 4 AND SPC.CODETYPE = 1 AND SPC.SPECODE = (select top 1 SRV.SPECODE from LG_001_SRVCARD SRV WHERE SRV.LOGICALREF = STL.STOCKREF))  AS 'Grup',
--(select TOP 1 DEFINITION_ from LG_001_SPECODES SPC WHERE SPC.SPECODETYPE  = 4 AND SPC.CODETYPE = 1 AND SPC.SPECODE = (select top 1 SRV.SPECODE2 from LG_001_SRVCARD SRV WHERE SRV.LOGICALREF = STL.STOCKREF))  AS '2.Gider Kategori',
(select TOP 1 DEFINITION_ from LG_001_SPECODES SPC WHERE SPC.SPECODETYPE  = 4 AND SPC.CODETYPE = 1 AND SPC.SPECODE = (select top 1 SRV.SPECODE3 from LG_001_SRVCARD SRV WHERE SRV.LOGICALREF = STL.STOCKREF))  AS 'Tür',
--(select top 1 SRV.DEFINITION_ from LG_001_SRVCARD SRV WHERE SRV.LOGICALREF = STL.STOCKREF) AS '4.Gider Kalemi',
SUM(CASE WHEN STL.VATINC  = 0  THEN  STL.TOTAL * (1 + STL.VAT /100) -  DISTCOST * (1 + STL.VAT /100)  ELSE   STL.TOTAL -  DISTCOST * (1 + STL.VAT /100)  END) AS 'Tutar'



FROM LG_001_01_INVOICE INV INNER JOIN LG_001_01_STLINE STL ON INV.LOGICALREF = STL.INVOICEREF 
AND INV.TRCODE = 4
AND INV.CANCELLED = 0
AND INV.BRANCH = 0 
AND STL.STOCKREF &lt;&gt;0
AND INV.DATE_ BETWEEN  @StartDate AND @EndDate
AND STL.TOTAL &gt; 0
GROUP BY 
STL.STOCKREF


UNION ALL


----------- VERİLEN HİZMET -----------------------------

SELECT '7' as 'SıraNo', 'Hizmet Satış' as 'Kategori',
'Verilen Hizmet'  AS 'Grup',SPC.DEFINITION_ as 'Tür',
sum((CASE WHEN STL.VATINC  = 0  THEN  STL.TOTAL * (1 + STL.VAT /100) -  DISTCOST * (1 + STL.VAT /100)  ELSE   STL.TOTAL -  DISTCOST * (1 + STL.VAT /100)  END)) AS 'Tutar'



FROM LG_001_01_STLINE STL 
INNER JOIN LG_001_01_INVOICE INV ON STL.INVOICEREF = INV.LOGICALREF
LEFT JOIN LG_001_ITEMS ITM ON STL.STOCKREF = ITM.LOGICALREF
LEFT JOIN LG_001_SPECODES SPC ON SPC.SPECODE = CASE WHEN STL.LINETYPE = 0 THEN ITM.SPECODE WHEN STL.LINETYPE  = 4 THEN (SELECT TOP 1 SPECODE FROM LG_001_SRVCARD SRV WHERE SRV.LOGICALREF = STL.STOCKREF) END
 
LEFT JOIN LG_001_SPECODES SPCC ON SPCC.SPECODE = ITM.STGRPCODE

WHERE 

INV.BRANCH =  0
AND INV.CANCELLED = 0 
AND INV.TRCODE IN (9) 
AND SPC.CODETYPE = 1
AND   SPC.SPECODETYPE  = CASE WHEN STL.LINETYPE = 0  THEN 1 WHEN STL.LINETYPE = 4 THEN 5 END
AND SPCC.SPECODETYPE = 0
AND SPCC.CODETYPE = 4
AND INV.DATE_ BETWEEN @StartDate AND @EndDate
GROUP BY SPCC.DEFINITION_ ,SPC.DEFINITION_

UNION ALL

------------- Hizmet Toplamları --------------------


SELECT '8' as 'SıraNo',
'Hizmet Toplamları' as 'Kategori',

Case when INV.TRCODE = 4  THEN  'Alınan Hizmet Toplamları' else 'Verilen Hizmet Toplamları' end AS 'Grup',

Case when INV.TRCODE = 4  THEN  'Alınan Hizmetler' else 'Verilen Hizmetler' end AS 'Tür',
--(select top 1 SRV.DEFINITION_ from LG_001_SRVCARD SRV WHERE SRV.LOGICALREF = STL.STOCKREF) AS '4.Gider Kalemi',
CASE WHEN INV.TRCODE = 4 THEN SUM(CASE WHEN STL.VATINC  = 0  THEN  STL.TOTAL * (1 + STL.VAT /100) -  DISTCOST * (1 + STL.VAT /100)  ELSE   STL.TOTAL -  DISTCOST * (1 + STL.VAT /100)  END) WHEN  INV.TRCODE =9 THEN -1 * SUM(CASE WHEN STL.VATINC  = 0  THEN  STL.TOTAL * (1 + STL.VAT /100) -  DISTCOST * (1 + STL.VAT /100)  ELSE   STL.TOTAL -  DISTCOST * (1 + STL.VAT /100)  END) END AS 'Tutar'



FROM LG_001_01_INVOICE INV INNER JOIN LG_001_01_STLINE STL ON INV.LOGICALREF = STL.INVOICEREF 
AND INV.TRCODE IN ( 4,9)
AND INV.CANCELLED = 0
AND INV.BRANCH = 0 
AND STL.STOCKREF &lt;&gt;0
AND INV.DATE_ BETWEEN @StartDate AND @EndDate
AND STL.TOTAL &gt; 0
GROUP BY 
INV.TRCODE


UNION ALL



---------------- BRÜT SATIŞ KARI  VEYA ZARARI  ----------------------
SELECT '9' as 'SıraNo',
'Brüt Satış Kâr veya Zarar' as 'Kategori',
   SPCC.DEFINITION_  AS 'Grup',SPC.DEFINITION_ as 'Tür',
SUM((CASE WHEN STL.VATINC  = 0  THEN  STL.TOTAL * (1 + STL.VAT /100) -  DISTCOST * (1 + STL.VAT /100)  ELSE   STL.TOTAL -  DISTCOST * (1 + STL.VAT /100)  END) - (STL.OUTCOST * STL.AMOUNT) * (1 + STL.VAT /100)) As 'Tutar'



FROM LG_001_01_STLINE STL 
INNER JOIN LG_001_01_INVOICE INV ON STL.INVOICEREF = INV.LOGICALREF
LEFT JOIN LG_001_ITEMS ITM ON STL.STOCKREF = ITM.LOGICALREF
LEFT JOIN LG_001_SPECODES SPC ON SPC.SPECODE = CASE WHEN STL.LINETYPE = 0 THEN ITM.SPECODE WHEN STL.LINETYPE  = 4 THEN (SELECT TOP 1 SPECODE FROM LG_001_SRVCARD SRV WHERE SRV.LOGICALREF = STL.STOCKREF) END
 
LEFT JOIN LG_001_SPECODES SPCC ON SPCC.SPECODE = ITM.STGRPCODE

WHERE 

INV.BRANCH =  0
AND INV.CANCELLED = 0 
AND INV.TRCODE IN (7,8) 
AND SPC.CODETYPE = 1
AND   SPC.SPECODETYPE  = CASE WHEN STL.LINETYPE = 0  THEN 1 WHEN STL.LINETYPE = 4 THEN 5 END
AND SPCC.SPECODETYPE = 0
AND SPCC.CODETYPE = 4
AND INV.DATE_ BETWEEN @StartDate AND @EndDate
GROUP BY SPCC.DEFINITION_ ,SPC.DEFINITION_


UNION ALL

SELECT '9' as 'SıraNo',
'Brüt Satış Kâr veya Zarar' as 'Kategori',
   SPCC.DEFINITION_  AS 'Grup',SPC.DEFINITION_ as 'Tür',
SUM((CASE WHEN STL.VATINC  = 0  THEN  STL.TOTAL * (1 + STL.VAT /100) -  DISTCOST * (1 + STL.VAT /100)  ELSE   STL.TOTAL -  DISTCOST * (1 + STL.VAT /100)  END) - (STL.OUTCOST * STL.AMOUNT) * (1 + STL.VAT /100)) * -1 As 'Tutar'



FROM LG_001_01_STLINE STL 
INNER JOIN LG_001_01_INVOICE INV ON STL.INVOICEREF = INV.LOGICALREF
LEFT JOIN LG_001_ITEMS ITM ON STL.STOCKREF = ITM.LOGICALREF
LEFT JOIN LG_001_SPECODES SPC ON SPC.SPECODE = CASE WHEN STL.LINETYPE = 0 THEN ITM.SPECODE WHEN STL.LINETYPE  = 4 THEN (SELECT TOP 1 SPECODE FROM LG_001_SRVCARD SRV WHERE SRV.LOGICALREF = STL.STOCKREF) END
 
LEFT JOIN LG_001_SPECODES SPCC ON SPCC.SPECODE = ITM.STGRPCODE

WHERE 

INV.BRANCH =  0
AND INV.CANCELLED = 0 
AND INV.TRCODE IN (2,3) 
AND SPC.CODETYPE = 1
AND   SPC.SPECODETYPE  = CASE WHEN STL.LINETYPE = 0  THEN 1 WHEN STL.LINETYPE = 4 THEN 5 END
AND SPCC.SPECODETYPE = 0
AND SPCC.CODETYPE = 4
AND INV.DATE_ BETWEEN @StartDate AND @EndDate
GROUP BY SPCC.DEFINITION_ ,SPC.DEFINITION_

order by SıraNo asc</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="SıraNo">
          <DataField>SıraNo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Kategori">
          <DataField>Kategori</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Grup">
          <DataField>Grup</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Tür">
          <DataField>Tür</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Tutar">
          <DataField>Tutar</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
