<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=ERP;Initial Catalog=LOGODB</ConnectString>
        <Prompt>Enter a user name and password to access the data source:</Prompt>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>66fb5a63-cdcb-44a4-a11b-74d480b77d36</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
(select TOP 1 DEFINITION_ from LG_001_SPECODES SPC WHERE SPC.SPECODETYPE  = 4 AND SPC.CODETYPE = 1 AND SPC.SPECODE = (select top 1 SRV.SPECODE from LG_001_SRVCARD SRV WHERE SRV.LOGICALREF = STL.STOCKREF))  AS '1.Gider Türü',
(select TOP 1 DEFINITION_ from LG_001_SPECODES SPC WHERE SPC.SPECODETYPE  = 4 AND SPC.CODETYPE = 1 AND SPC.SPECODE = (select top 1 SRV.SPECODE2 from LG_001_SRVCARD SRV WHERE SRV.LOGICALREF = STL.STOCKREF))  AS '2.Gider Kategori',
(select TOP 1 DEFINITION_ from LG_001_SPECODES SPC WHERE SPC.SPECODETYPE  = 4 AND SPC.CODETYPE = 1 AND SPC.SPECODE = (select top 1 SRV.SPECODE3 from LG_001_SRVCARD SRV WHERE SRV.LOGICALREF = STL.STOCKREF))  AS '3.Gider Bilgisi',
(select top 1 SRV.DEFINITION_ from LG_001_SRVCARD SRV WHERE SRV.LOGICALREF = STL.STOCKREF) AS '4.Gider Kalemi',
SUM(CASE WHEN STL.VATINC  = 0  THEN  STL.TOTAL * (1 + STL.VAT /100) -  DISTCOST * (1 + STL.VAT /100)  ELSE   STL.TOTAL -  DISTCOST * (1 + STL.VAT /100)  END) AS 'Tutar'



FROM LG_001_01_INVOICE INV INNER JOIN LG_001_01_STLINE STL ON INV.LOGICALREF = STL.INVOICEREF AND INV.TRCODE = 4 AND INV.CANCELLED = 0 AND INV.BRANCH = 0 
AND STL.STOCKREF &lt;&gt;0
AND INV.DATE_ BETWEEN @StartDate AND @EndDate



GROUP BY 
STL.STOCKREF</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ID1_Gider_Türü">
          <DataField>1.Gider Türü</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ID2_Gider_Kategori">
          <DataField>2.Gider Kategori</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ID3_Gider_Bilgisi">
          <DataField>3.Gider Bilgisi</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Tutar">
          <DataField>Tutar</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="ID4_Gider_Kalemi">
          <DataField>4.Gider Kalemi</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
